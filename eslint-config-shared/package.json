{
  "name": "@bjj/eslint-config-shared",
  "version": "0.2.0",
  "description": "Eslint@10 shared config",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --clean --dts",
    "lint": "eslint --fix",
    "release": "npm run release:bjj && npm run release:polymarbot",
    "release:bjj": "node ../scripts/publish.mjs --scope @bjj",
    "release:polymarbot": "node ../scripts/publish.mjs --scope @polymarbot"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "eslint": ">= 10"
  },
  "dependencies": {
    "@eslint/js": "^10.0.0",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.0.0",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@stylistic/eslint-plugin": "^5.2.0",
    "eslint-plugin-better-tailwindcss": "^4.3.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-vue": "^10.1.0",
    "globals": "^17.0.0",
    "lodash-es": "^4.17.21",
    "typescript-eslint": "^8.32.1",
    "vue-eslint-parser": "^10.1.3"
  },
  "devDependencies": {
    "@eslint/config-helpers": "^0.3.0",
    "@types/lodash-es": "^4.17.12",
    "eslint": "^10.0.0",
    "react": "^19.1.1",
    "tailwindcss": "^4.1.13",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
