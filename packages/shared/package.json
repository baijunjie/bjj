{
  "name": "@bjj/shared",
  "version": "0.1.0",
  "description": "Shared utilities",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./utils-browser": {
      "types": "./dist/utils-browser/index.d.ts",
      "import": "./dist/utils-browser/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --clean --dts",
    "test": "vitest run",
    "lint": "eslint --fix",
    "release": "npm run release:bjj && npm run release:polymarbot",
    "release:bjj": "tsx ../../scripts/publish.ts --name @bjj/shared --token BJJ_NPM_TOKEN",
    "release:polymarbot": "tsx ../../scripts/publish.ts --name @polymarbot/uitls-shared --token POLYMARBOT_NPM_TOKEN"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "glob": "^11.0.2",
    "lodash-es": "^4.17.21",
    "unplugin": "^2.3.4"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  }
}