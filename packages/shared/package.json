{
  "name": "@bjj/shared",
  "version": "0.3.5",
  "description": "Shared utilities",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./utils-browser": {
      "types": "./dist/utils-browser/index.d.ts",
      "import": "./dist/utils-browser/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js"
    },
    "./vue/utils": {
      "types": "./dist/vue/utils/index.d.ts",
      "import": "./dist/vue/utils/index.js"
    },
    "./vue/composables": {
      "types": "./dist/vue/composables/index.d.ts",
      "import": "./dist/vue/composables/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --clean --dts",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "lint": "git add . && lint-staged --config ../../.lintstagedrc.lint-only.json",
    "format": "git add . && lint-staged --config ../../.lintstagedrc.json",
    "release": "npm run build && npm run release:bjj && npm run release:polymarbot && npm run release:elepay",
    "release:bjj": "tsx ../../scripts/publish.ts --name @bjj/shared --token BJJ_NPM_TOKEN",
    "release:polymarbot": "tsx ../../scripts/publish.ts --name @polymarbot/uitls-shared --token POLYMARBOT_NPM_TOKEN",
    "release:elepay": "tsx ../../scripts/publish.ts --name @elepay-io/frontend-shared --token ELEPAY_IO_NPM_TOKEN --registry https://npm.pkg.github.com/"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dompurify": "^3.4.0",
    "glob": "^11.0.2",
    "lodash-es": "^4.17.21",
    "tailwind-merge": "^3.5.0",
    "unplugin": "^2.3.4"
  },
  "peerDependencies": {
    "@vueuse/core": "*",
    "dayjs": "^1",
    "vue": "^3",
    "vue-i18n": "^11",
    "vue-router": "^4 || ^5",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@vueuse/core": "^14.2.0",
    "dayjs": "^1.11.20",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.1",
    "vue": "^3.5.0",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.5.0",
    "vue-tsc": "^3.2.7",
    "zod": "^4.3.6"
  }
}