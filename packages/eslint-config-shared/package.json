{
  "name": "@bjj/eslint-config-shared",
  "version": "0.2.4",
  "description": "Eslint@10 shared config",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --clean --dts",
    "lint": "eslint --fix",
    "release": "npm run release:bjj && npm run release:polymarbot",
    "release:bjj": "tsx ../../scripts/publish.ts --name @bjj/eslint-config-shared --token BJJ_NPM_TOKEN",
    "release:polymarbot": "tsx ../../scripts/publish.ts --name @polymarbot/eslint-config-shared --token POLYMARBOT_NPM_TOKEN"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "eslint": ">= 10"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.5.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "lodash-es": "^4.17.23",
    "typescript-eslint": "^8.57.1"
  },
  "devDependencies": {
    "@eslint/config-helpers": "^0.5.3",
    "@types/lodash-es": "^4.17.12",
    "eslint": "^10.0.3",
    "react": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}