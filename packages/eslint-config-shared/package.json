{
  "name": "@bjj/eslint-config-shared",
  "version": "0.2.1",
  "description": "Eslint@10 shared config",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --clean --dts",
    "lint": "eslint --fix",
    "release": "npm run release:bjj && npm run release:polymarbot",
    "release:bjj": "tsx ../../scripts/publish.ts --name @bjj/eslint-config-shared --token BJJ_NPM_TOKEN",
    "release:polymarbot": "tsx ../../scripts/publish.ts --name @polymarbot/eslint-config-shared --token POLYMARBOT_NPM_TOKEN"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@eslint-react/eslint-plugin": ">= 3",
    "@eslint/js": ">= 10",
    "@eslint/json": ">= 1",
    "@eslint/markdown": ">= 7",
    "@stylistic/eslint-plugin": ">= 5",
    "eslint": ">= 10",
    "eslint-plugin-better-tailwindcss": ">= 4",
    "eslint-plugin-react-refresh": ">= 0.5",
    "eslint-plugin-vue": ">= 10",
    "typescript-eslint": ">= 8"
  },
  "peerDependenciesMeta": {
    "@eslint-react/eslint-plugin": {
      "optional": true
    },
    "@eslint/json": {
      "optional": true
    },
    "@eslint/markdown": {
      "optional": true
    },
    "eslint-plugin-better-tailwindcss": {
      "optional": true
    },
    "eslint-plugin-react-refresh": {
      "optional": true
    },
    "eslint-plugin-vue": {
      "optional": true
    }
  },
  "dependencies": {
    "globals": "^17.0.0",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@eslint/config-helpers": "^0.5.3",
    "@eslint/js": "^10.0.0",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.0.0",
    "@stylistic/eslint-plugin": "^5.2.0",
    "@types/lodash-es": "^4.17.12",
    "eslint": "^10.0.0",
    "eslint-plugin-better-tailwindcss": "^4.3.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-vue": "^10.1.0",
    "react": "^19.1.1",
    "tailwindcss": "^4.1.13",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}