{
  "name": "@bjj/nuxt-layer-shadcn-ui",
  "version": "0.1.2",
  "description": "Nuxt layer providing shadcn-vue based UI components",
  "type": "module",
  "main": "./nuxt.config.ts",
  "exports": {
    ".": "./nuxt.config.ts",
    "./*": "./*"
  },
  "files": [
    "app",
    "i18n",
    "i18n.config.ts",
    "nuxt.config.ts"
  ],
  "scripts": {
    "prepare": "nuxt prepare .playground",
    "typecheck": "nuxt prepare .playground && nuxt typecheck .playground",
    "lint": "git add . && lint-staged --config ../../.lintstagedrc.lint-only.json",
    "format": "git add . && lint-staged --config ../../.lintstagedrc.json",
    "shadcn:add": "npx shadcn-vue@latest add",
    "storybook": "cd .playground && storybook dev -p 6006",
    "storybook:build": "cd .playground && storybook build",
    "i18n:build": "tsx scripts/i18n/build && pnpm i18n:fix:alignment",
    "i18n:check:undefined": "tsx scripts/i18n/checkUndefinedKeys",
    "i18n:check:unused": "tsx scripts/i18n/checkUnusedKeys",
    "i18n:fix:unused": "tsx scripts/i18n/checkUnusedKeys --fix && pnpm i18n:build",
    "i18n:fix:alignment": "tsx scripts/i18n/checkI18nAlignment --fix",
    "release": "npm run release:bjj && npm run release:polymarbot && npm run release:elepay",
    "release:bjj": "tsx ../../scripts/publish.ts --name @bjj/nuxt-layer-shadcn-ui --token BJJ_NPM_TOKEN",
    "release:polymarbot": "tsx ../../scripts/publish.ts --name @polymarbot/nuxt-layer-shadcn-ui --token POLYMARBOT_NPM_TOKEN --rewrite '@bjj/nuxt-layer-shadcn-ui=@polymarbot/nuxt-layer-shadcn-ui' --rewrite '@bjj/shared=@polymarbot/uitls-shared'",
    "release:elepay": "tsx ../../scripts/publish.ts --name @elepay-io/nuxt-layer-shadcn-ui --token ELEPAY_IO_NPM_TOKEN --registry https://npm.pkg.github.com/ --rewrite '@bjj/nuxt-layer-shadcn-ui=@elepay-io/nuxt-layer-shadcn-ui' --rewrite '@bjj/shared=@elepay-io/frontend-shared'"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/vue-table": "^8.21.3",
    "@vuepic/vue-datepicker": "^12.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lodash-es": "^4.18.1",
    "lucide-vue-next": "^1.0.0",
    "qrcode": "^1.5.4",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "vue-sonner": "^2.0.9"
  },
  "peerDependencies": {
    "@bjj/shared": "^0.2.0",
    "@nuxtjs/i18n": "^10",
    "@vueuse/core": "^14",
    "dayjs": "^1",
    "nuxt": "^4",
    "vue": "^3",
    "vue-i18n": "^11",
    "vue-router": "^4 || ^5"
  },
  "devDependencies": {
    "@bjj/eslint-config-shared": "workspace:*",
    "@nuxt/eslint": "^1.15.2",
    "@nuxtjs/i18n": "^10",
    "@storybook-vue/nuxt": "9.1.0-29411911.f34c865",
    "@storybook/vue3": "~9.1.0",
    "@types/lodash-es": "^4.17.12",
    "@types/qrcode": "^1.5.6",
    "storybook": "^10.3.5"
  }
}